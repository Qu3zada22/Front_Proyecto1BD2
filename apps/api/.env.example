# ============================================================
# FastPochi API — Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- MongoDB local (Docker) ----
# Levantar primero con: docker compose up -d
MONGODB_URI=mongodb://localhost:27017/fastpochi?replicaSet=rs0

# ---- MongoDB Atlas (producción) ----
# MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/fastpochi?retryWrites=true&w=majority

# ---- JWT ----
JWT_SECRET=cambia_esto_en_produccion
JWT_EXPIRES_IN=7d
