{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "inputs": ["src/**", "package.json", "tsconfig.json"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "test": {
            "outputs": ["coverage/**"],
            "inputs": ["src/**/*.ts", "test/**/*.ts"]
        },
        "test:cov": {
            "outputs": ["coverage/**"],
            "inputs": ["src/**/*.ts", "test/**/*.ts"]
        },
        "lint": {
            "outputs": []
        },
        "clean": {
            "cache": false
        }
    }
}
